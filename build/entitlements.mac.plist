<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow unsigned code (for dev builds without Apple Developer ID) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading third-party plugins / dynamic libraries (nut-js) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Screen recording (desktopCapturer + screencapture fallback) -->
    <key>com.apple.security.device.screen-capture</key>
    <true/>

    <!-- Microphone for voice conversation -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Accessibility / automation for nut-js mouse/keyboard control -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Network access (localhost server + Anam/Anthropic APIs) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access for the file-tool and history persistence -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
